# Canonical URL for metadata, sitemap, robots (use your production domain on Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required on Vercel production builds (optional locally — dev falls back to template defaults)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# NEXT_PUBLIC_SANITY_USE_CDN=true

# Contact form (Resend). Add these on Vercel for production.
# https://resend.com/docs/send-with-nextjs
# Verified sending domain: message.studio-finity.com
RESEND_API_KEY=
# Recipient inbox (defaults to hello@studio-finity.com if unset)
CONTACT_TO_EMAIL=
# Must use an address on the verified domain, e.g. Studio Finity <hello@message.studio-finity.com>
CONTACT_FROM_EMAIL=

# Contact API rate limiting (recommended on Vercel). Create a free Redis database at https://upstash.com
# and paste REST URL + REST token. Without these, a per-instance memory limiter is used (weaker on serverless).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
