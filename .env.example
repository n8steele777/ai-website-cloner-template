# Canonical URL for metadata, sitemap, robots (use your production domain on Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional dev-only: Agentation Agent Sync server (e.g. http://localhost:4747). Do NOT set to this app's URL — that causes /health and /sessions 404 noise.
# NEXT_PUBLIC_AGENTATION_ENDPOINT=http://localhost:4747

# Required on Vercel production builds (optional locally — dev falls back to template defaults)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# NEXT_PUBLIC_SANITY_USE_CDN=true
